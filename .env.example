# ----- Network Settings -----
SERVER_IP=YOUR_SERVER_IP
# Fallback / Stealth domain for XTLS Reality
REALITY_DEST=www.microsoft.com:443
REALITY_SERVER_NAME=www.microsoft.com

# ----- Ports -----
XRAY_PORT=443

# ----- XRAY Secrets -----
# The UUID for the 'admin' or 'default' target user
XRAY_PRIVATE_KEY=
XRAY_PUBLIC_KEY=
XRAY_SHORT_ID=

# ----- ANTI-TORRENT FIREWALL -----
# Controls whether to apply the DOCKER-USER iptables firewall rules
ENABLE_FIREWALL=true

# Firewall Mode: 'balanced' or 'strict'
# 'balanced': Blocks typical P2P/Torrent ports (6881-6999). Allows everything else.
# 'strict'  : Whitelist behavior. Only allows Web (TCP 80/443) and DNS. Blocks everything else, including QUIC (UDP 443).
FIREWALL_MODE=balanced
